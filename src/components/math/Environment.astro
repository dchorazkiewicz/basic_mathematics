---
interface Props {
  kind?: 'definition' | 'theorem' | 'example' | 'remark';
  label?: string;
  title?: string;
  id?: string;
}

const {
  kind = 'definition',
  label = kind === 'definition'
    ? 'Definicja'
    : kind === 'theorem'
      ? 'Twierdzenie'
      : kind === 'example'
        ? 'Przykład'
        : 'Uwaga',
  title,
  id
} = Astro.props;
---

<section id={id} class={`math-environment math-environment--${kind}`}>
  <header class="math-environment__heading">
    <span>{label}</span>
    {title && <span>— {title}</span>}
  </header>
  <div class="math-environment__body">
    <slot />
  </div>
</section>
